{
  "version": 2,
  "buildCommand": "npm install && npx prisma generate --schema=backend/prisma/schema.prisma && cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "node_modules/.prisma/client/**",
      "runtime": "nodejs20.x"
    }
  }
}
